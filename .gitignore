# MinOS — Gitignore

# ── Private / local-only files ────────────────────────────────────────────────
DEMO.md

# ── Disk & filesystem images (large, fully generated by make) ──────────────────
myos.img
os-root.squashfs
initramfs-stage1.cpio
initramfs.cpio
*.cpio
*.img
*.squashfs

# ── Kernel binary (14 MB — rebuild with: bash build/fix_kernel_config.sh) ─────
kernel/bzImage

# ── Compiled binaries (all rebuilt by make) ────────────────────────────────────
# init
init/init

# supervisor
supervisor/supervisor

# daemons
cgroup/cgmgr
netd/netd

# runtime
runtime/minc
runtime/minc.o

# tools
tools/cginspect
tools/nslist
tools/memhog

# projects
projects/sysmon/sysmon
projects/pyrun/pyrun

# rootfs staging directory (populated by make, not source files)
rootfs/bin/
rootfs/sbin/
rootfs/lib/
rootfs/services/
rootfs/services.d/

# ── Build state ───────────────────────────────────────────────────────────────
.stamps/
build/boot.log
build/stage1-root/
build/phase_check_*.log

# ── Stale / accidental root-level binaries ────────────────────────────────────
bin/busybox
bin/mingetty
supervisor.bin
supervisor_bin

# ── Object & dependency files ─────────────────────────────────────────────────
*.o
*.d
*.a

# ── Merge conflict leftovers ──────────────────────────────────────────────────
*.resolved
*.orig

# ── WSL Windows Zone.Identifier sidecars ──────────────────────────────────────
*Zone.Identifier
*.Identifier

# ── Language runtimes (large — staged by: bash build/setup-langs.sh) ──────────
# Python 3.12 standalone binary + stdlib (~80 MB uncompressed)
# TCC compiled binary + headers
# These are NOT source — regenerate with: bash build/setup-langs.sh
.lang-build/
rootfs/usr/
rootfs/root/
rootfs/home/

# ── Editor / OS junk ──────────────────────────────────────────────────────────
.DS_Store
*.swp
*~
\#*\#
.idea/
*.code-workspace
.vscode/
