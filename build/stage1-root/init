#!/bin/sh
# initramfs-stage1/init
# Stage-1 Bootstrap — mounts squashfs+overlay then switch_roots to real OS.
#
# Disk layout:
#   vda1 (or sda1) → ext4  (boot + persistent overlay upper/work)
#   vda2 (or sda2) → squashfs written RAW as a block device (no loop needed!)
#
# Flow:
#   1. Mount /proc /sys (kernel gives us /dev via devtmpfs)
#   2. Find vda1/sda1 (ext4 boot partition)
#   3. Mount vda2/sda2 directly as squashfs → /squash
#   4. Set up overlay → /newroot
#   5. switch_root /newroot /sbin/init

mount -t proc  none /proc
mount -t sysfs none /sys
# /dev is auto-mounted by kernel when CONFIG_DEVTMPFS_MOUNT=y
if ! mountpoint -q /dev 2>/dev/null; then
    mount -t tmpfs tmpfs /dev 2>/dev/null || true
    mdev -s 2>/dev/null || true
fi

mkdir -p /mnt /squash /newroot

echo "[stage1] waiting for boot disk..."
BOOT=""   # e.g. /dev/vda1
SQFS=""   # e.g. /dev/vda2
TRIES=0
while [ $TRIES -lt 30 ]; do
    if [ -b /dev/vda2 ]; then
        BOOT=/dev/vda1; SQFS=/dev/vda2; break   # VirtIO
    elif [ -b /dev/sda2 ]; then
        BOOT=/dev/sda1; SQFS=/dev/sda2; break   # IDE/SATA
    fi
    sleep 0.2
    TRIES=$((TRIES+1))
done

if [ -z "$SQFS" ]; then
    echo "[stage1] ERROR: no boot disk found"
    echo "[stage1] Available block devices:"
    cat /proc/partitions 2>/dev/null
    exec /bin/sh
fi
echo "[stage1] Boot: $BOOT   Squashfs: $SQFS"

# Mount boot partition (ext4, rw — hosts the persistent overlay)
echo "[stage1] mounting boot partition ($BOOT)..."
mount -t ext4 "$BOOT" /mnt || {
    echo "[stage1] ERROR: could not mount $BOOT as ext4"
    exec /bin/sh
}

# Mount squashfs DIRECTLY as a block device — no loop device needed!
echo "[stage1] mounting squashfs OS root ($SQFS)..."
mount -t squashfs -o ro "$SQFS" /squash || {
    echo "[stage1] ERROR: squashfs mount of $SQFS failed"
    echo "[stage1] Kernel squashfs support:"
    grep squashfs /proc/filesystems 2>/dev/null || echo "  not found"
    exec /bin/sh
}

# Create persistent overlay dirs on the boot partition
mkdir -p /mnt/overlay/upper /mnt/overlay/work

# Mount overlay: reads from squashfs, writes to ext4 (persist across reboots)
echo "[stage1] mounting overlay..."
mount -t overlay overlay \
    -o lowerdir=/squash,upperdir=/mnt/overlay/upper,workdir=/mnt/overlay/work \
    /newroot || {
    echo "[stage1] ERROR: overlay mount failed"
    echo "[stage1] Kernel overlay support:"
    grep overlay /proc/filesystems 2>/dev/null || echo "  not found"
    exec /bin/sh
}

# Move essential mounts into new root (survive the switch_root)
mkdir -p /newroot/proc /newroot/sys /newroot/dev /newroot/mnt
mount --move /proc  /newroot/proc
mount --move /sys   /newroot/sys
# NOTE: Do NOT mount --move /dev — devtmpfs cannot be moved (EINVAL).
# /sbin/init (init/main.c) mounts devtmpfs fresh at /dev after switch_root.
mount --move /mnt   /newroot/mnt   # boot partition visible at /mnt in new root

echo "[stage1] switching to OS root..."
exec switch_root /newroot /sbin/init
